[
  {
    "name": "body_exposure_standalone",
    "description": "Single tag-toggle node — verifies node loads, accepts BOOLEAN inputs, and emits OUTPUT_NODE preview text via /history.",
    "workflow": {
      "1": {
        "class_type": "BodyExposure",
        "inputs": {
          "separator": ", ",
          "preset": "custom",
          "nude": true,
          "completely_nude": false,
          "partially_nude": false,
          "extra": ""
        }
      }
    },
    "expect": [
      ["1", "nude"]
    ]
  },
  {
    "name": "exposure_through_tags_merge",
    "description": "Wires a tag bundle into TagsMerge — verifies the CUUN_TAGS socket type and merge resolution work end-to-end.",
    "workflow": {
      "1": {
        "class_type": "BodyExposure",
        "inputs": {
          "separator": ", ",
          "preset": "custom",
          "nude": true,
          "completely_nude": false,
          "partially_nude": false,
          "extra": ""
        }
      },
      "2": {
        "class_type": "TagsMerge",
        "inputs": {
          "separator": ", ",
          "bundle_1": ["1", 1]
        }
      }
    },
    "expect": [
      ["1", "nude"],
      ["2", "nude"]
    ]
  },
  {
    "name": "pony_prompt_builder",
    "description": "Pure-text node — verifies COMBO inputs (rating, source) and BOOLEAN score toggles produce the expected ordering.",
    "workflow": {
      "1": {
        "class_type": "PonyPromptBuilder",
        "inputs": {
          "separator": ", ",
          "score_9": true,
          "score_8_up": true,
          "score_7_up": true,
          "score_6_up": false,
          "score_5_up": false,
          "score_4_up": false,
          "rating": "safe",
          "source": "anime",
          "extra": "1girl"
        }
      }
    },
    "expect": [
      ["1", "score_9"],
      ["1", "rating_safe"],
      ["1", "source_anime"],
      ["1", "1girl"]
    ]
  },
  {
    "name": "three_presets_through_merge",
    "description": "Mirrors the text portion of example_workflows/character_pipeline.json — three preset bundles fanning into TagsMerge.",
    "workflow": {
      "1": {"class_type": "CharacterPreset", "inputs": {"preset": "miko", "separator": ", ", "extra": ""}},
      "2": {"class_type": "PersonalityPreset", "inputs": {"personality": "genki", "separator": ", ", "extra": ""}},
      "3": {"class_type": "SituationPreset", "inputs": {"situation": "shrine_visit", "separator": ", ", "extra": ""}},
      "4": {
        "class_type": "TagsMerge",
        "inputs": {
          "separator": ", ",
          "bundle_1": ["1", 1],
          "bundle_2": ["2", 1],
          "bundle_3": ["3", 1]
        }
      }
    },
    "expect": [
      ["4", "miko"],
      ["4", "shrine"],
      ["4", "smile"]
    ]
  },
  {
    "name": "character_preset",
    "description": "Preset combo selector — verifies COMBO with a non-trivial value list resolves to expected tags.",
    "workflow": {
      "1": {
        "class_type": "CharacterPreset",
        "inputs": {
          "preset": "miko",
          "separator": ", ",
          "extra": ""
        }
      }
    },
    "expect": [
      ["1", "miko"],
      ["1", "hakama"]
    ]
  },
  {
    "name": "tag_decorate_color",
    "description": "TagDecorate prefixes a clothing.bottoms tag from a CharacterPreset bundle with colors emitted by ColorPalette. Verifies the tag-category registry resolves preset-emitted tags and the decoration phrase is correctly composed.",
    "workflow": {
      "1": {
        "class_type": "CharacterPreset",
        "inputs": {
          "preset": "serafuku_schoolgirl",
          "separator": ", ",
          "extra": ""
        }
      },
      "2": {
        "class_type": "ColorPalette",
        "inputs": {
          "separator": ", ",
          "preset": "custom",
          "red": true,
          "pink": false,
          "orange": false,
          "yellow": false,
          "green": true,
          "blue": false,
          "light_blue": false,
          "dark_blue": false,
          "purple": false,
          "violet": false,
          "brown": false,
          "tan": false,
          "beige": false,
          "black": false,
          "white": false,
          "gray": false,
          "silver": false,
          "gold": false,
          "navy": false,
          "teal": false,
          "cyan": false,
          "magenta": false,
          "crimson": false,
          "maroon": false,
          "olive": false,
          "lime": false,
          "aqua": false,
          "ivory": false,
          "pastel": false,
          "neon": false,
          "extra": ""
        }
      },
      "3": {
        "class_type": "TagDecorate",
        "inputs": {
          "separator": ", ",
          "target_category": "clothing.bottoms",
          "bundle": ["1", 1],
          "decoration": ["2", 1]
        }
      }
    },
    "expect": [
      ["3", "red green pleated skirt"],
      ["3", "thighhighs"]
    ]
  },
  {

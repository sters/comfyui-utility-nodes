          "crimson": false,
          "maroon": false,
          "olive": false,
          "lime": false,
          "aqua": false,
          "ivory": false,
          "pastel": false,
          "neon": false,
          "extra": ""
        }
      },
      "3": {
        "class_type": "TagsExplode",
        "inputs": {
          "bundle": ["2", 1]
        }
      },
      "4": {
        "class_type": "TagDecorate",
        "inputs": {
          "separator": ", ",
          "target_category": "clothing.bottoms",
